from backend.database.db import CurrentSession, CurrentSessionTransaction

router = APIRouter()


@router.get(
    '',
    summary='{{ doc_comment }}列表',
    dependencies=[DependsAgentAuth],
)
async def agent_list_{{ table_name }}s(
    db: CurrentSession,
    x_user_id: Annotated[str, Header(description='用户 UUID')],
) -> ResponseModel:
    user_id = await resolve_user_id(db, x_user_id)
    data = await {{ table_name }}_service.get_list(db=db, user_id=user_id)
    return response_base.success(data=data)


@router.post(
    '',
    summary='创建{{ doc_comment }}',
    dependencies=[DependsAgentAuth],
)
async def agent_create_{{ table_name }}(
    db: CurrentSessionTransaction,
    obj: Create{{ schema_name }}Param,
    x_user_id: Annotated[str, Header(description='用户 UUID')],
) -> ResponseModel:
