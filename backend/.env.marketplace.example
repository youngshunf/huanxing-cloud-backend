# ============================================================
# 技能市场配置示例
# ============================================================

# LLM API 网关配置（用于翻译服务）
LLM_API_BASE_URL='https://fuyou.cool'  # LLM 网关地址（支持 OpenAI 兼容 API）
LLM_API_KEY='sk-your-llm-api-key'  # LLM API Key
TRANSLATION_MODEL='gpt-5.4-mini'  # 翻译使用的模型

# huanxing-hub 本地路径配置
HUANXING_HUB_LOCAL_PATH='/Users/mac/openclaw-workspace/huanxing/huanxing-project/huanxing-hub'  # 本地开发路径
# HUANXING_HUB_LOCAL_PATH='/data/huanxing-hub'  # 生产环境路径

# ClawHub 同步配置
CLAWHUB_API_URL='https://clawhub.ai/api/v1'  # ClawHub API 地址
CLAWHUB_API_KEY='clh_your-clawhub-api-key'  # ClawHub API Key（可选，用于认证）

# ============================================================
# 配置说明
# ============================================================

# 1. LLM 翻译服务
#    - LLM_API_BASE_URL: LLM 网关地址，支持 OpenAI 兼容 API
#    - LLM_API_KEY: API Key，用于认证
#    - TRANSLATION_MODEL: 翻译模型，推荐使用 gpt-5.4-mini 或 gpt-4o-mini
#
#    注意：
#    - 必须支持非流式响应（stream: false）
#    - 如果使用 new-api 等网关，确保配置正确

# 2. huanxing-hub 本地路径
#    - HUANXING_HUB_LOCAL_PATH: huanxing-hub 仓库的本地路径
#    - 用于存储从 ClawHub 同步的技能文件
#    - 下载时从此路径打包 zip 文件
#
#    目录结构：
#    huanxing-hub/
#    ├── clawhub/           # ClawHub 同步的技能
#    │   └── {owner}/
#    │       └── {slug}/
#    │           ├── SKILL.md
#    │           ├── _meta.json
#    │           ├── scripts/
#    │           └── references/
#    └── skills/            # 本地开发的技能

# 3. ClawHub 同步配置
#    - CLAWHUB_API_URL: ClawHub API 的基础 URL
#    - CLAWHUB_API_KEY: ClawHub API Key（可选）
#
#    同步流程：
#    1. 从 ClawHub API 获取技能元数据
#    2. 翻译 name 和 description（支持混合语言）
#    3. 下载技能 zip 文件并解压到 huanxing-hub
#    4. 保存 repo_path 到数据库
#
#    下载流程：
#    1. 用户请求下载技能
#    2. 从 repo_path 打包 zip 文件
#    3. 返回 FileResponse（不依赖 CDN）

# ============================================================
# 测试命令
# ============================================================

# 测试翻译服务：
# uv run python -c "
# import asyncio
# from backend.app.marketplace.service.translation_service import translation_service
#
# async def test():
#     result = await translation_service.translate('Hello World', 'en', 'zh')
#     print(result)
#
# asyncio.run(test())
# "

# 测试 ClawHub 同步：
# uv run python scripts/test_clawhub_sync.py

# 测试下载功能：
# curl "http://127.0.0.1:8020/api/v1/marketplace/download/skill/clawhub/mnetfairy/insurance-advisor-china/latest" -o test.zip

# ============================================================
# 常见问题
# ============================================================

# Q: 翻译服务返回空结果？
# A: 检查 LLM_API_BASE_URL 是否正确，确保支持非流式响应

# Q: 下载时提示文件不存在？
# A: 检查 HUANXING_HUB_LOCAL_PATH 是否正确，确保技能已同步

# Q: ClawHub 同步失败？
# A: 检查 CLAWHUB_API_URL 和 CLAWHUB_API_KEY 是否正确

# Q: repo_path 为空？
# A: 确保同步时下载功能正常，检查日志中的下载信息

