# Huanxing Cloud Backend — .env.example (M1)
#
# 本文件只存占位，真实值走 Vault + CI secret 注入到 runtime 环境。
# 对应 Vault 路径: secret/huanxing/backend/umeng
#
# 说明：友盟 U-Push（推送下发）与 U-App（埋点统计）共用同一 AppKey；
# APP_MASTER_SECRET 仅服务端持有，用于签名 U-Push HTTP API（见 PRD B5）。

# 友盟 AppKey（与移动端 app/.env.example UMENG_APP_KEY 同值）
UMENG_APP_KEY=
# 友盟 App Master Secret（仅后端持有，严禁下发到客户端 / 公开仓库）
UMENG_APP_MASTER_SECRET=
